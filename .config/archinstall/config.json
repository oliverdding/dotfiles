{
    "audio": "pipewire",
    "bootloader": "systemd-bootctl",
    "custom-commands": [
        "usermod -aG docker devel"
    ],
    "filesystem": "btrfs",
    "gfx_driver": "Intel (open-source)",
    "harddrives": [
        "/dev/nvme0n1"
    ],
    "swap": true,
    "hostname": "alpha",
    "kernels": [
        "linux-zen"
    ],
    "keyboard-language": "us",
    "mirror-region": {
        "China": {
            "https://mirrors.ustc.edu.cn/archlinux/$repo/os/$arch": true,
            "https://mirrors.tuna.tsinghua.edu.cn/archlinux/$repo/os/$arch": true,
            "https://mirrors.tencent.com/archlinux/$repo/os/$arch": true
        }
    },
    "nic": {
        "NetworkManager": true
    },
    "ntp": true,
    "packages": ["docker", "git", "fish"],
    "profile": "sway",
    "services": ["docker"],
    "sys-encoding": "utf-8",
    "sys-language": "en_US",
    "timezone": "Asia/Shanghai"
}