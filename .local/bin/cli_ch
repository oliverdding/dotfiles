#!/usr/bin/env bash

function help() {
    echo -e "ClickHouse client for quickly access database online.\nUsage: $0 [r,t,b,tke1.8] [...]"
}

[[ $# -eq 0 ]] && {
    error "Need target database."
    help
    exit 1
}

case $1 in
r | release)
    CLICK_HOUSE_HOST='10.16.0.85'
    CLICK_HOUSE_USER='root'
    ;;
t | test)
    CLICK_HOUSE_HOST='10.16.30.2'
    CLICK_HOUSE_USER='root'
    ;;
b | backup)
    CLICK_HOUSE_HOST='10.16.30.12'
    CLICK_HOUSE_USER='root'
    ;;
tke1.8)
    CLICK_HOUSE_HOST='127.0.0.1'
    CLICK_HOUSE_USER='qapm'
    ;;
*)
    error "Unknown target dataabse"
    help
    exit 2
    ;;
esac

shift 1
execute_in_intranet "clickhouse-client -h $CLICK_HOUSE_HOST -u $CLICK_HOUSE_USER --ask-password -m $@"
