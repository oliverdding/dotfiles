#!/usr/bin/env bash

function help() {
    echo -e "ClickHouse client for quickly access database online.\nUsage: $0 [r,t,b,tke1.8] [...]"
}

[[ $# -eq 0 ]] && {
    error "Need target database."
    help
    exit 1
}

case $1 in
r | release)
    CLICK_HOUSE_HOST='10.16.0.85'
    ;;
t | test)
    CLICK_HOUSE_HOST='10.16.30.2'
    ;;
b | backup)
    CLICK_HOUSE_HOST='10.16.30.12'
    ;;
*)
    error "Unknown target dataabse"
    help
    exit 2
    ;;
esac

shift 1
[[ -z "$CLICK_HOUSE_PASSWORD" ]] && {
    execute_in_intranet "clickhouse-client -h $CLICK_HOUSE_HOST -u root --ask-password -m $@"
} || {
    execute_in_intranet "clickhouse-client -h $CLICK_HOUSE_HOST -u root --password $CLICK_HOUSE_PASSWORD -m $@"
}
